# ── Polymarket CLOB ───────────────────────────────────────
# Export these from your Polymarket account / py-clob-client setup.
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here
POLY_PRIVATE_KEY=0xyour_signer_private_key_here

# Optional: required for proxy-wallet / magic-link / Safe-backed accounts.
# If omitted, the bot will try to auto-discover the proxy wallet from CLOB.
POLY_FUNDER_ADDRESS=0xyour_proxy_or_funder_wallet_here
# Optional override:
#   0 = EOA
#   1 = Magic/email proxy wallet
#   2 = Gnosis/browser proxy wallet (common for newer Polymarket accounts)
POLY_SIGNATURE_TYPE=2

# ── Dashboard ─────────────────────────────────────────────
DASHBOARD_PASSWORD=changeme

# ── Kalshi (optional — enables cross-platform arbitrage) ──
# Step 1: Create account at kalshi.com
# Step 2: Account → API Keys → Generate RSA Key Pair
# Step 3: Base64-encode your private key PEM:
#   python3 -c "import base64; print(base64.b64encode(open('key.pem','rb').read()).decode())"
# Step 4: Add both values below and set cross_platform_arb.enabled: true in config.yaml
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY=
